                                                                        <Button Grid.Column="1" Content="지우기" Command="{Binding DataContext.ClearColumnFilterCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="Note" Margin="2,0,0,0" Height="22" FontSize="10" Padding="0"/>
                                                                    </Grid>
                                                                    <Thumb Grid.Row="3" Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="SizeNWSE" DragDelta="PopupResizeThumb_DragDelta" Margin="0,0,-2,-2">
