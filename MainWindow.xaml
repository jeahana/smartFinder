                      Background="{DynamicResource PanelBg}" Foreground="{DynamicResource TextFg}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- File Path and Copy Button Bar -->
                    <Border Grid.Row="0" Margin="0,0,0,8" Padding="5" CornerRadius="4"
                            Background="{DynamicResource StatusBg}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="filePathTextBox" Grid.Column="0" IsReadOnly="True" 
