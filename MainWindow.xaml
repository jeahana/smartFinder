                                                                        <Button Grid.Column="1" Content="지우기" Command="{Binding DataContext.ClearColumnFilterCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="LineText" Margin="2,0,0,0" Height="22" FontSize="10" Padding="0"/>
