<Window x:Class="smartFinder.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="환경설정" Height="280" Width="650"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="app_icon.ico"
        Background="{DynamicResource WindowBg}"
        Foreground="{DynamicResource TextFg}"
        ShowInTaskbar="False">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="일반 및 에디터 설정" Grid.Row="0" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="에디터 경로:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Text="{Binding EditorPath, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="1" VerticalContentAlignment="Center" Height="25"/>
                <Button Content="..." Command="{Binding BrowseEditorCommand}" Grid.Row="0" Grid.Column="2" Width="30" Height="28" Margin="5,0,0,0"/>

                <TextBlock Text="파라미터:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Text="{Binding EditorArgs, UpdateSourceTrigger=PropertyChanged}" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" VerticalContentAlignment="Center" Height="25"
                         ToolTip="에디터 파라미터 양식입니다. %path%는 파일경로(폴더), %file_name%은 파일명(확장자 포함), %line_no%는 라인번호로 치환됩니다."/>

                <!-- Theme selection row -->
                <Grid Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Text="테마 분류:" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox SelectedValue="{Binding ThemeCategory, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content" Grid.Column="1" Height="25" VerticalContentAlignment="Center">
                        <ComboBoxItem Content="Light"/>
                        <ComboBoxItem Content="Dark"/>
                    </ComboBox>
                    
                    <TextBlock Text="세부 테마:" Grid.Column="3" VerticalAlignment="Center" Margin="15,0,10,0"/>
                    <ComboBox ItemsSource="{Binding AvailableSubThemes}" SelectedItem="{Binding SelectedSubTheme, UpdateSourceTrigger=PropertyChanged}" Grid.Column="4" Height="25" VerticalContentAlignment="Center"/>
                </Grid>
            </Grid>
        </GroupBox>

        <Button Content="확인" Click="OkButton_Click" Grid.Row="1" Width="80" Height="28" Margin="0,10,0,0" HorizontalAlignment="Right" IsDefault="True"/>
    </Grid>
</Window>
